# ──────────────────────────────────────────────────────────────────
# Paisabot — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env
# ──────────────────────────────────────────────────────────────────

# ── Flask ──────────────────────────────────────────────────────────
FLASK_APP=app:create_app
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string

# Fernet key for encrypting API keys in system_config
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ── Database ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://paisabot:paisabot@localhost:5432/paisabot
TEST_DATABASE_URL=sqlite://

# ── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
TEST_REDIS_URL=redis://localhost:6379/15

# ── Alpaca (Primary Broker) ───────────────────────────────────────
# Paper trading: https://app.alpaca.markets/paper/dashboard/overview
# Live trading: https://app.alpaca.markets/
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# ── Market Data Providers ─────────────────────────────────────────
# Polygon.io — real-time + historical bars
POLYGON_API_KEY=

# Finnhub — news, sentiment, economic calendar
FINNHUB_API_KEY=

# ── Sentiment / NLP ───────────────────────────────────────────────
# Reddit (PRAW) — for Reddit sentiment factor
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=paisabot/1.0

# ── Notifications (Optional) ──────────────────────────────────────
# Slack webhook for alert notifications
SLACK_WEBHOOK_URL=

# Email alerts (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# ── Operational ────────────────────────────────────────────────────
# Default operational mode: research | simulation | live
OPERATIONAL_MODE=simulation

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

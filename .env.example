# ──────────────────────────────────────────────────────────────────
# Paisabot — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env
# ──────────────────────────────────────────────────────────────────

# ── Flask ──────────────────────────────────────────────────────────
FLASK_APP=app:create_app
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-string

# Fernet key for encrypting API keys in system_config
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=KGwCApDNXFMytjzDoBCgHxsl8h-gZfj4Oky-2Ts98DI=

# Admin dashboard password
ADMIN_PASSWORD=

# ── Database ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://paisabot:paisabot@127.0.0.1:5432/paisabot
TEST_DATABASE_URL=sqlite://

# ── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
TEST_REDIS_URL=redis://127.0.0.1:6379/15

# ── CORS (WebSocket origins) ──────────────────────────────────────
# Comma-separated list of allowed origins for WebSocket connections.
# Set to your domain in production.
CORS_ALLOWED_ORIGINS=http://localhost:5000

# ── Alpaca (Primary Broker) ───────────────────────────────────────
# Paper trading: https://app.alpaca.markets/paper/dashboard/overview
# Live trading: https://app.alpaca.markets/
ALPACA_API_KEY=PKQWHQBGMECI6T2VCUKADFIHGK
ALPACA_SECRET_KEY=9r528C7SnhGSaXfrJHAxNZ68pbk1U2rfdvzihfdvThM7
ALPACA_PAPER=true

# ── Market Data Providers ─────────────────────────────────────────
# Polygon.io — real-time + historical bars
POLYGON_API_KEY=SQuP09CeqJSpZpsQdwWeijW5Qjv2vlgd

# Finnhub — news, sentiment,  calendar
FINNHUB_API_KEY=d6r3cohr01qgdhqd0pj0d6r3cohr01qgdhqd0pjg

# ── Sentiment / NLP ───────────────────────────────────────────────
# Reddit (PRAW) — for Reddit sentiment factor
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=paisabot/1.0

# ── Notifications (Optional) ──────────────────────────────────────
# Slack webhook for alert notifications
SLACK_WEBHOOK_URL=

# Email alerts (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# ── MetaTrader 5 (Optional — Windows only) ───────────────────────
# For CMC Markets, Admiral Markets, or other MT5-connected brokers.
# MT5 trades ETF CFDs (not spot ETFs). Terminal must be running locally.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=CMCMarkets-Demo
MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# ── Operational ────────────────────────────────────────────────────
# Default operational mode: research | simulation | live
OPERATIONAL_MODE=simulation

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Gunicorn (Production) ─────────────────────────────────────────
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
PORT=5000
